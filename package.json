{
  "name": "milton",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "A Microsoft Excel add-in for Bring-Your-Own-Model agentic spreadsheet interactions.",
  "license": "MIT",
  "packageManager": "pnpm@11.2.2+sha512.36e6621fad506178936455e70247b8808ef4ec25797a9f437a93281a020484e2607f6a469a22e982987c3dbb8866e3071514ab10a4a1749e06edcd1ec118436f",
  "config": {
    "app_to_debug": "excel",
    "app_type_to_debug": "desktop",
    "dev_server_port": 3000
  },
  "scripts": {
    "dev": "vite --host localhost --port 3000",
    "dev-server": "vite --host localhost --port 3000",
    "build": "tsc --noEmit && vite build",
    "start": "office-addin-debugging start office/manifest.xml",
    "stop": "office-addin-debugging stop office/manifest.xml",
    "validate": "office-addin-manifest validate office/manifest.xml"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.2.64",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "office-addin-debugging": "^6.0.3",
    "office-addin-dev-certs": "^2.0.3",
    "office-addin-dev-settings": "^3.1.1",
    "office-addin-manifest": "^2.0.3",
    "semver": "^7.8.1",
    "typescript": "^5.4.2",
    "vite": "^5.4.11"
  }
}
